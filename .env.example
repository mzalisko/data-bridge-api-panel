# DataBridgeApi — Environment Configuration Template
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
# This file is parsed by parse_ini_file() — do not use shell export syntax.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_NAME=data_bridge
DB_USER=root
DB_PASS=

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
# APP_ENV: production | development | testing
APP_ENV=development

# APP_DEBUG: true to show errors and stack traces, false in production
APP_DEBUG=true

# APP_URL: Base URL of the application (no trailing slash)
APP_URL=http://localhost

# APP_SECRET: Random 64-char string used for signing tokens, hashing, etc.
# Generate with: php -r "echo bin2hex(random_bytes(32));"
APP_SECRET=replace-with-a-long-random-string
